# ==============================================================================
# Telemt — Environment Variables
#
# Copy this file to .env and fill in your values, or set these variables
# directly in Dokploy's Environment Variables section.
#
# Required variables MUST be set. Optional variables have sensible defaults.
# ==============================================================================


# ------------------------------------------------------------------------------
# REQUIRED — You must set these for each server
# ------------------------------------------------------------------------------

# 32-character hex string. This is the proxy secret shared with users.
# Generate with: openssl rand -hex 16
# Example: 545d50e4498f858068a14f99c6886741
TELEMT_SECRET=

# Your server's public IP address.
# Used in the announce field so Telegram clients can find the correct DC route.
# Example: 47.128.145.75
TELEMT_SERVER_IP=

# Domain or IP that users connect to. Embedded in the tg:// link.
# Must resolve to your server (DNS-only / gray cloud if using Cloudflare).
# Example: api.aitb.ir
TELEMT_PUBLIC_HOST=


# ------------------------------------------------------------------------------
# OPTIONAL — These have defaults that work for most deployments
# ------------------------------------------------------------------------------

# SNI domain for FakeTLS. DPI sees traffic going "to" this domain.
# Must be: unblocked in target country, popular, serves real HTTPS on port 443.
# Telemt fetches this domain's real TLS certificate for byte-perfect emulation.
# Default: www.google.com
# TELEMT_TLS_DOMAIN=www.google.com

# Username label for the secret in the config. Just an internal identifier.
# Default: main
# TELEMT_USER_NAME=main

# Port the proxy listens on inside the container.
# 443 is strongly recommended (looks like normal HTTPS to DPI).
# Default: 443
# TELEMT_PORT=443

# Port embedded in the tg:// link. Usually matches the listen port.
# Default: same as TELEMT_PORT
# TELEMT_PUBLIC_PORT=443

# Log verbosity: debug | verbose | normal | silent
# Default: normal
# TELEMT_LOG_LEVEL=normal
